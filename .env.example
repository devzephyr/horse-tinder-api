# Database
DATABASE_URL=postgresql+asyncpg://horsetinder:password@localhost:5432/horsetinder

# JWT Secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))")
ACCESS_TOKEN_SECRET=dev-access-secret-change-me-in-production-min-32-bytes
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me-in-production-min-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_STORAGE_URI=memory://

# CORS (JSON list of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# App
APP_ENV=development
LOG_LEVEL=INFO
